{
	"name": "NestJS API Agenda",
	"dockerComposeFile": [
		"../compose.yml",
		"docker-compose.yml"
	],
	"service": "app",
	"workspaceFolder": "/workspace",
	"customizations": {
		"vscode": {
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode"
			},
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"Prisma.prisma"
			]
		}
	},
	"forwardPorts": [3000, 5432, 8080],
	"postCreateCommand": "npm i -g pnpm && pnpm install && npx prisma generate"
}
